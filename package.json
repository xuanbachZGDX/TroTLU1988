{
  "name": "trotlu1988-root",
  "version": "1.0.0",
  "private": true,
  "description": "Root configuration for Git hooks and development tools",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.0.11",
    "lint-staged": "^15.2.5",
    "prettier": "^3.2.5"
  },
  "lint-staged": {
    "client/src/**/*.{js,jsx,ts,tsx,css,json}": [
      "prettier --write"
    ],
    "server/src/**/*.{js,json}": [
      "prettier --write"
    ],
    "*.{js,json,md}": [
      "prettier --write"
    ]
  }
}
